function getColor(v){
  if(v<=50)  return '#27ae60';
  if(v<=100) return '#7dbb3b';
  if(v<=200) return '#f1c40f';
  if(v<=300) return '#e67e22';
  if(v<=400) return '#e74c3c';
  return '#8e44ad';
}
function getCat(v){
  if(v<=50)  return 'Good';
  if(v<=100) return 'Satisfactory';
  if(v<=200) return 'Moderate';
  if(v<=300) return 'Poor';
  if(v<=400) return 'Very poor';
  return 'Severe';
}

let selYear = 2025;
let selRegion = 'All';
let lineChartInst, barChartInst, donutChartInst;

// ── YEAR SLICER ──
const yearSlicer = document.getElementById('yearSlicer');
YEARS.forEach(y => {
  const b = document.createElement('div');
  b.className = 'slicer-btn' + (y===2025?' active':'');
  b.textContent = y;
  b.dataset.year = y;
  b.addEventListener('click', () => {
    document.querySelectorAll('#yearSlicer .slicer-btn').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');
    selYear = y;
    refresh();
  });
  yearSlicer.appendChild(b);
});

// ── REGION SLICER ──
document.querySelectorAll('#regionSlicer .slicer-btn').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('#regionSlicer .slicer-btn').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');
    selRegion = b.dataset.region;
    refresh();
  });
});

function getFilteredStates(){
  let states = Object.keys(AQI_DATA);
  if(selRegion !== 'All') states = states.filter(s => REGIONS[selRegion]?.includes(s));
  const cat = document.getElementById('catFilter').value;
  if(cat !== 'All') states = states.filter(s => getCat(AQI_DATA[s][selYear]) === cat);
  return states;
}

function refresh(){
  document.getElementById('mapYearLabel').textContent = selYear;
  document.getElementById('tableYear').textContent = selYear;
  document.getElementById('barYear').textContent = selYear;
  document.getElementById('trendSpan').textContent = selRegion!=='All'?'· '+selRegion:'';
  renderKPIs();
  renderMap();
  renderLineChart();
  renderBarChart();
  renderDonut();
  renderTable();
  renderGauges();
}

// ── KPIs ──
function renderKPIs(){
  const nat = NATIONAL[selYear];
  const prev = selYear > 2015 ? NATIONAL[selYear-1] : null;
  const diff = prev ? nat - prev : 0;
  const states = getFilteredStates();
  const vals = states.map(s=>({s,v:AQI_DATA[s][selYear]}));
  vals.sort((a,b)=>a.v-b.v);
  const avgAll = Math.round(vals.reduce((a,x)=>a+x.v,0)/vals.length);

  const kpis = [
    {label:'National Avg AQI',value:nat,sub:getCat(nat),trend:diff,color:'#e94560'},
    {label:'Filtered Avg AQI',value:avgAll,sub:selRegion+' region',trend:null,color:'#0f9b8e'},
    {label:'States Monitored',value:states.length,sub:'of 33 total',trend:null,color:'#7b68ee'},
    {label:'Cleanest State',value:vals[0]?.s||'—',sub:'AQI '+vals[0]?.v,trend:null,color:'#27ae60',isText:true},
    {label:'Most Polluted',value:vals[vals.length-1]?.s||'—',sub:'AQI '+vals[vals.length-1]?.v,trend:null,color:'#e74c3c',isText:true},
  ];

  document.getElementById('kpiRow').innerHTML = kpis.map(k=>`
    <div class="kpi" style="--accent-color:${k.color}">
      <div class="kpi-label">${k.label}</div>
      <div class="kpi-value" style="font-size:${k.isText?'16px':'26px'};color:${k.color}">${k.value}</div>
      <div class="kpi-sub">
        <span>${k.sub}</span>
        ${k.trend!==null?`<span class="kpi-trend ${k.trend<0?'dn':'up'}">${k.trend<0?'↓':'↑'} ${Math.abs(k.trend)}</span>`:''}
      </div>
    </div>`).join('');
}

// ── MAP ──
function renderMap(){
  const svg = document.getElementById('mapSvg');
  svg.innerHTML = '';
  const tt = document.getElementById('mapTooltip');
  const filtered = new Set(getFilteredStates());

  Object.entries(STATE_PATHS).forEach(([state,d])=>{
    const val = AQI_DATA[state]?.[selYear]??0;
    const isFiltered = filtered.has(state);
    const fill = isFiltered ? getColor(val) : '#2a3a5a';
    const path = document.createElementNS('http://www.w3.org/2000/svg','path');
    path.setAttribute('d',d);
    path.setAttribute('fill',fill);
    path.setAttribute('stroke','rgba(255,255,255,0.15)');
    path.setAttribute('stroke-width','0.7');
    path.classList.add('state-path');
    if(!isFiltered) path.style.opacity='0.35';
    path.addEventListener('mouseenter',()=>{ path.style.opacity='0.65'; });
    path.addEventListener('mouseleave',()=>{ path.style.opacity = isFiltered?'1':'0.35'; tt.style.display='none'; });
    path.addEventListener('mousemove',(e)=>{
      tt.style.display='block';
      tt.style.left=(e.clientX+14)+'px';
      tt.style.top=(e.clientY-36)+'px';
      const prev = selYear>2015?AQI_DATA[state][selYear-1]:null;
      const chg = prev?((val-prev>0?'↑':'↓')+' '+Math.abs(val-prev)+' vs '+((selYear-1))):'';
      tt.innerHTML=`<b>${state}</b><span>AQI: ${val} · ${getCat(val)}<br/>${chg}</span>`;
    });
    svg.appendChild(path);

    try{
      const b=path.getBBox();
      if(b.width>28&&isFiltered){
        const t=document.createElementNS('http://www.w3.org/2000/svg','text');
        t.setAttribute('x',b.x+b.width/2);
        t.setAttribute('y',b.y+b.height/2+4);
        t.setAttribute('text-anchor','middle');
        t.setAttribute('font-size','7.5');
        t.setAttribute('fill','#fff');
        t.setAttribute('font-weight','600');
        t.setAttribute('pointer-events','none');
        t.textContent=val;
        svg.appendChild(t);
      }
    }catch(e){}
  });
}

// ── LINE CHART ──
function renderLineChart(){
  const ctx=document.getElementById('lineChart');
  if(lineChartInst){lineChartInst.destroy();}
  const states=getFilteredStates();

  let data;
  if(selRegion==='All'){
    data = YEARS.map(y=>NATIONAL[y]);
  } else {
    data = YEARS.map(y=>{
      const vals=states.map(s=>AQI_DATA[s][y]);
      return Math.round(vals.reduce((a,v)=>a+v,0)/vals.length);
    });
  }

  lineChartInst=new Chart(ctx,{
    type:'line',
    data:{
      labels:YEARS,
      datasets:[{
        label:'Avg AQI',
        data,
        borderColor:'#e94560',
        backgroundColor:'rgba(233,69,96,0.08)',
        fill:true,
        tension:0.35,
        pointRadius:YEARS.map(y=>y===selYear?6:3),
        pointBackgroundColor:YEARS.map(y=>y===selYear?'#f5a623':'#e94560'),
        pointBorderColor:'transparent',
        borderWidth:2,
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{
        backgroundColor:'#16213e',
        titleColor:'#e8eaf6',
        bodyColor:'#8892b0',
        borderColor:'rgba(255,255,255,0.1)',
        borderWidth:1,
        callbacks:{label:c=>` AQI ${c.parsed.y} · ${getCat(c.parsed.y)}`}
      }},
      scales:{
        x:{ticks:{color:'#8892b0',font:{size:10},maxRotation:45,autoSkip:false},grid:{color:'rgba(255,255,255,0.04)'}},
        y:{ticks:{color:'#8892b0',font:{size:10}},grid:{color:'rgba(255,255,255,0.06)'}}
      }
    }
  });
}

// ── BAR CHART ──
function renderBarChart(){
  const ctx=document.getElementById('barChart');
  if(barChartInst){barChartInst.destroy();}
  const states=getFilteredStates();
  const vals=states.map(s=>({s,v:AQI_DATA[s][selYear]})).sort((a,b)=>b.v-a.v).slice(0,8);

  barChartInst=new Chart(ctx,{
    type:'bar',
    data:{
      labels:vals.map(x=>x.s.length>12?x.s.slice(0,12)+'…':x.s),
      datasets:[{
        data:vals.map(x=>x.v),
        backgroundColor:vals.map(x=>getColor(x.v)+'cc'),
        borderColor:vals.map(x=>getColor(x.v)),
        borderWidth:1,
        borderRadius:2,
      }]
    },
    options:{
      indexAxis:'y',
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{
        backgroundColor:'#16213e',borderColor:'rgba(255,255,255,0.1)',borderWidth:1,
        titleColor:'#e8eaf6',bodyColor:'#8892b0',
        callbacks:{label:c=>` AQI ${c.parsed.x} · ${getCat(c.parsed.x)}`}
      }},
      scales:{
        x:{ticks:{color:'#8892b0',font:{size:10}},grid:{color:'rgba(255,255,255,0.05)'}},
        y:{ticks:{color:'#8892b0',font:{size:10}},grid:{display:false}}
      }
    }
  });
}

// ── DONUT ──
function renderDonut(){
  const ctx=document.getElementById('donutChart');
  if(donutChartInst){donutChartInst.destroy();}
  const states=getFilteredStates();
  const cats={Good:0,Satisfactory:0,Moderate:0,Poor:0,'Very poor':0,Severe:0};
  states.forEach(s=>{ cats[getCat(AQI_DATA[s][selYear])]++; });
  const labels=Object.keys(cats).filter(k=>cats[k]>0);
  const vals=labels.map(k=>cats[k]);
  const colors={'Good':'#27ae60','Satisfactory':'#7dbb3b','Moderate':'#f1c40f','Poor':'#e67e22','Very poor':'#e74c3c','Severe':'#8e44ad'};

  donutChartInst=new Chart(ctx,{
    type:'doughnut',
    data:{labels,datasets:[{data:vals,backgroundColor:labels.map(l=>colors[l]+'cc'),borderColor:labels.map(l=>colors[l]),borderWidth:1}]},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{
        backgroundColor:'#16213e',borderColor:'rgba(255,255,255,0.1)',borderWidth:1,
        titleColor:'#e8eaf6',bodyColor:'#8892b0',
      }},
      cutout:'65%',
    }
  });

  const total=vals.reduce((a,v)=>a+v,0);
  document.getElementById('donutLegend').innerHTML=labels.map((l,i)=>`
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3px">
      <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:#8892b0">
        <div style="width:8px;height:8px;border-radius:1px;background:${colors[l]};flex-shrink:0"></div>${l}
      </div>
      <span style="font-size:10px;color:#e8eaf6;font-weight:600">${vals[i]} <span style="color:#8892b0;font-weight:400">(${Math.round(vals[i]/total*100)}%)</span></span>
    </div>`).join('');
}

// ── TABLE ──
function renderTable(){
  const states=getFilteredStates();
  const rows=states.map(s=>({s,v:AQI_DATA[s][selYear],prev:selYear>2015?AQI_DATA[s][selYear-1]:null}));
  rows.sort((a,b)=>b.v-a.v);
  const max=rows[0]?.v||1;
  const catColors={Good:'#27ae60',Satisfactory:'#7dbb3b',Moderate:'#f1c40f',Poor:'#e67e22','Very poor':'#e74c3c',Severe:'#8e44ad'};

  document.getElementById('stateTableBody').innerHTML=rows.map((r,i)=>{
    const cat=getCat(r.v);
    const chg=r.prev?r.v-r.prev:null;
    const chgStr=chg!==null?(chg<0?`<span style="color:#27ae60">↓${Math.abs(chg)}</span>`:`<span style="color:#e74c3c">↑${chg}</span>`):'—';
    return `<tr>
      <td style="color:#8892b0">${i+1}</td>
      <td style="font-weight:500">${r.s}</td>
      <td style="font-weight:700;color:${getColor(r.v)}">${r.v}</td>
      <td><span class="aqi-pill" style="background:${catColors[cat]}22;color:${catColors[cat]};border:1px solid ${catColors[cat]}44">${cat}</span></td>
      <td>${chgStr}</td>
      <td><div class="bar-cell"><div class="bar-mini" style="width:${Math.round(r.v/max*80)}px;background:${getColor(r.v)}"></div></div></td>
    </tr>`;
  }).join('');
}

// ── GAUGES ──
function drawArc(canvasId,pct,color,label){
  const c=document.getElementById(canvasId);
  if(!c)return;
  const ctx=c.getContext('2d');
  ctx.clearRect(0,0,c.width,c.height);
  const cx=c.width/2,cy=c.height-8,r=34;
  ctx.beginPath();
  ctx.arc(cx,cy,r,Math.PI,2*Math.PI);
  ctx.strokeStyle='rgba(255,255,255,0.08)';
  ctx.lineWidth=7;
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(cx,cy,r,Math.PI,Math.PI+Math.PI*Math.min(pct,1));
  ctx.strokeStyle=color;
  ctx.lineWidth=7;
  ctx.lineCap='round';
  ctx.stroke();
}

function renderGauges(){
  const states=getFilteredStates();
  const vals=states.map(s=>({s,v:AQI_DATA[s][selYear]})).sort((a,b)=>a.v-b.v);
  const best=vals[0]||{s:'—',v:0};
  const worst=vals[vals.length-1]||{s:'—',v:500};
  const nat=NATIONAL[selYear];
  const prev=selYear>2015?NATIONAL[selYear-1]:nat;
  const chg=nat-prev;

  drawArc('gauge1',best.v/500,getColor(best.v),best.s);
  document.getElementById('gv1').textContent=best.v;
  document.getElementById('gv1').style.color=getColor(best.v);
  document.getElementById('gc1').textContent=best.s;
  document.getElementById('gc1').style.background=getColor(best.v)+'33';
  document.getElementById('gc1').style.color=getColor(best.v);

  drawArc('gauge2',worst.v/500,getColor(worst.v),worst.s);
  document.getElementById('gv2').textContent=worst.v;
  document.getElementById('gv2').style.color=getColor(worst.v);
  document.getElementById('gc2').textContent=worst.s;
  document.getElementById('gc2').style.background=getColor(worst.v)+'33';
  document.getElementById('gc2').style.color=getColor(worst.v);

  const chgPct=Math.abs(chg)/50;
  const chgColor=chg<0?'#27ae60':'#e74c3c';
  drawArc('gauge3',chgPct,chgColor,'');
  document.getElementById('gv3').textContent=(chg<0?'↓':'+')+(chg);
  document.getElementById('gv3').style.color=chgColor;
  document.getElementById('gc3').textContent='vs '+(selYear-1);
  document.getElementById('gc3').style.background=chgColor+'33';
  document.getElementById('gc3').style.color=chgColor;
}

document.getElementById('catFilter').addEventListener('change',refresh);
document.getElementById('lastRefresh').textContent='Last refreshed: '+new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});

refresh();
</script>
