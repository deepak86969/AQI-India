    <div class="chart-panel">
      <div class="panel-title">AQI Category Distribution</div>
      <div style="position:relative;height:140px"><canvas id="donutChart"></canvas></div>
      <div id="donutLegend" style="margin-top:8px"></div>
    </div>
  </div>

  <!-- MAP + TABLE ROW -->
  <div class="map-row">
