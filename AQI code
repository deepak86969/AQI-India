<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>India AQI Dashboard — Power BI Style</title>
<link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@300;400;600;700&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --bg: #1a1a2e;
    --panel: #16213e;
    --card: #0f3460;
    --card2: #1b2a4a;
    --accent: #e94560;
    --accent2: #0f9b8e;
    --accent3: #f5a623;
    --accent4: #7b68ee;
    --text: #e8eaf6;
    --muted: #8892b0;
    --border: rgba(255,255,255,0.08);
    --good: #27ae60;
    --satisfactory: #7dbb3b;
    --moderate: #f1c40f;
    --poor: #e67e22;
    --verypoor: #e74c3c;
    --severe: #8e44ad;
    --font: 'Segoe UI', sans-serif;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg);color:var(--text);font-family:var(--font);font-size:13px;min-height:100vh;overflow-x:hidden}

  /* ── TOP HEADER ── */
  .topbar{background:var(--panel);border-bottom:1px solid var(--border);padding:0 20px;height:44px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
  .topbar-left{display:flex;align-items:center;gap:12px}
  .pbi-logo{display:flex;align-items:center;gap:8px;font-size:14px;font-weight:700;letter-spacing:0.3px}
  .pbi-logo svg{width:22px;height:22px}
  .topbar-title{font-size:13px;color:var(--muted);padding-left:12px;border-left:1px solid var(--border)}
  .topbar-right{display:flex;gap:8px;align-items:center}
  .tb-btn{background:transparent;border:1px solid var(--border);color:var(--muted);font-size:11px;padding:4px 10px;border-radius:3px;cursor:pointer;font-family:var(--font);transition:all 0.15s}
  .tb-btn:hover{background:rgba(255,255,255,0.05);color:var(--text)}
  .tb-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}

  /* ── FILTERS BAR ── */
  .filterbar{background:var(--panel);border-bottom:1px solid var(--border);padding:8px 20px;display:flex;align-items:center;gap:16px;flex-wrap:wrap}
  .filter-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap}
  .filter-group{display:flex;align-items:center;gap:8px}
  .slicer{display:flex;gap:4px;flex-wrap:wrap}
  .slicer-btn{background:var(--card2);border:1px solid var(--border);color:var(--muted);font-size:11px;padding:3px 9px;border-radius:2px;cursor:pointer;font-family:var(--font);transition:all 0.12s;white-space:nowrap}
  .slicer-btn:hover{border-color:var(--accent);color:var(--text)}
  .slicer-btn.active{background:var(--accent);border-color:var(--accent);color:#fff;font-weight:600}
  .filter-sep{width:1px;height:24px;background:var(--border)}
  select.fsel{background:var(--card2);border:1px solid var(--border);color:var(--text);font-size:11px;padding:4px 8px;border-radius:2px;font-family:var(--font);cursor:pointer;outline:none}
  select.fsel:focus{border-color:var(--accent)}

  /* ── MAIN CANVAS ── */
  .canvas{padding:14px 20px;display:grid;gap:12px;grid-template-rows:auto}

  /* ── KPI ROW ── */
  .kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
  .kpi{background:var(--card2);border:1px solid var(--border);border-radius:4px;padding:12px 14px;position:relative;overflow:hidden;cursor:default;transition:border-color 0.15s}
  .kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--accent-color,var(--accent))}
  .kpi:hover{border-color:rgba(255,255,255,0.15)}
  .kpi-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px}
  .kpi-value{font-size:26px;font-weight:700;line-height:1;margin-bottom:4px}
  .kpi-sub{font-size:10px;color:var(--muted);display:flex;align-items:center;gap:4px}
  .kpi-trend{font-size:10px;font-weight:600;padding:1px 5px;border-radius:2px}
  .kpi-trend.up{background:rgba(231,76,60,0.2);color:#e74c3c}
  .kpi-trend.dn{background:rgba(39,174,96,0.2);color:#27ae60}
  .kpi-icon{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:28px;opacity:0.12}

  /* ── CHART GRID ── */
  .chart-grid{display:grid;grid-template-columns:2fr 1.4fr 1fr;gap:12px}
  .chart-panel{background:var(--card2);border:1px solid var(--border);border-radius:4px;padding:14px}
  .panel-title{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.6px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between}
  .panel-title span{color:var(--text);font-size:12px;font-weight:700;text-transform:none;letter-spacing:0}

  /* ── MAP ROW ── */
  .map-row{display:grid;grid-template-columns:1.2fr 1fr;gap:12px}

  /* ── TABLE ── */
  .tbl{width:100%;border-collapse:collapse}
  .tbl th{font-size:10px;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);padding:6px 8px;border-bottom:1px solid var(--border);text-align:left;font-weight:600}
  .tbl td{padding:5px 8px;border-bottom:1px solid rgba(255,255,255,0.04);font-size:12px;color:var(--text)}
  .tbl tr:last-child td{border-bottom:none}
  .tbl tr:hover td{background:rgba(255,255,255,0.03)}
  .aqi-pill{display:inline-block;padding:2px 7px;border-radius:2px;font-size:10px;font-weight:600}
  .bar-cell{display:flex;align-items:center;gap:6px}
  .bar-mini{height:6px;border-radius:2px;min-width:2px}

  /* ── LEGEND ── */
  .legend{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px}
  .leg-item{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--muted)}
  .leg-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0}

  /* ── MAP SVG ── */
  #mapSvg{width:100%;height:auto;display:block}
  .state-path{transition:opacity 0.12s;cursor:pointer}
  .state-path:hover{opacity:0.7;stroke-width:1.5!important}

  /* ── SCROLLABLE TABLE CONTAINER ── */
  .tbl-scroll{max-height:300px;overflow-y:auto}
  .tbl-scroll::-webkit-scrollbar{width:4px}
  .tbl-scroll::-webkit-scrollbar-track{background:transparent}
  .tbl-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

  /* ── GAUGE ── */
  .gauge-wrap{display:flex;flex-direction:column;align-items:center;padding:8px 0}
  .gauge-label{font-size:11px;color:var(--muted);margin-top:6px}
  .gauge-value{font-size:22px;font-weight:700;margin-top:2px}
  .gauge-cat{font-size:10px;font-weight:600;padding:2px 8px;border-radius:10px;margin-top:4px}

  /* ── FOOTER ── */
  .dash-footer{display:flex;align-items:center;justify-content:space-between;padding:6px 20px;background:var(--panel);border-top:1px solid var(--border);font-size:10px;color:var(--muted)}

  /* ── RESPONSIVE ── */
  @media(max-width:900px){
    .kpi-row{grid-template-columns:repeat(3,1fr)}
    .chart-grid{grid-template-columns:1fr}
    .map-row{grid-template-columns:1fr}
  }

  /* ── TOOLTIP ── */
  #mapTooltip{position:fixed;background:var(--panel);border:1px solid var(--border);border-radius:4px;padding:8px 12px;font-size:12px;pointer-events:none;display:none;z-index:999;box-shadow:0 4px 16px rgba(0,0,0,0.4)}
  #mapTooltip b{display:block;font-weight:600;margin-bottom:3px;color:var(--text)}
  #mapTooltip span{color:var(--muted)}

  .page-indicator{display:flex;gap:4px}
  .page-dot{width:28px;height:4px;border-radius:1px;background:var(--border);cursor:pointer;transition:background 0.15s}
  .page-dot.active{background:var(--accent)}
</style>
</head>
