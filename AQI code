          <div class="gauge-value" id="gv3">—</div>
          <div class="gauge-cat" id="gc3">—</div>
        </div>
      </div>
      <!-- Data Table -->
      <div class="chart-panel" style="flex:1;padding:12px">
        <div class="panel-title" style="margin-bottom:8px">State Rankings — <span id="tableYear">2025</span></div>
        <div class="tbl-scroll">
          <table class="tbl">
            <thead><tr>
